# Coltura environment variables — copy to .env.local and fill in.
# Nothing here is required to run the local-first app shell; these power
# the Stage-1/2 AI features (handwriting transcription, ball-band OCR, synthesis).

# Anthropic API key for vision/LLM calls made from serverless routes (server-side only).
ANTHROPIC_API_KEY=

# Optional: Ravelry personal API credentials (read-only personal import + link-out only).
# RAVELRY_USERNAME=
# RAVELRY_PASSWORD=
